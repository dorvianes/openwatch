{
    "name": "dorvianes/openwatch",
    "description": "Remote monitoring package for Laravel applications using OpenWatch",
    "type": "library",
    "keywords": [
        "laravel",
        "monitoring",
        "observability",
        "telemetry",
        "openwatch"
    ],
    "homepage": "https://github.com/dorvianes/openwatch",
    "support": {
        "issues": "https://github.com/dorvianes/openwatch/issues",
        "source": "https://github.com/dorvianes/openwatch"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Dorvianes\\OpenWatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dorvianes\\OpenWatch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dorvianes\\OpenWatch\\OpenWatchServiceProvider"
            ],
            "aliases": {
                "OpenWatch": "Dorvianes\\OpenWatch\\Facades\\OpenWatch"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "illuminate/http": "13.0"
    }
}
